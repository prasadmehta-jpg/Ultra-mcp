{
  "name": "ultra-mcp",
  "version": "0.2.0",
  "description": "Ultra MCP: a provider-agnostic AI-to-AI collaboration layer and MCP server. One request, many AI minds, one synthesized answer.",
  "type": "module",
  "bin": {
    "ultra-mcp": "dist/server.js",
    "ultra-mcp-cli": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md", ".env.example"],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "cli": "tsx src/cli.ts",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node dist/server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0",
    "@google/genai": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.7",
    "openai": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
