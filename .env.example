# --- Cloud provider keys (add the ones you have; Ultra runs with any subset) ---
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here

# --- Local provider (privacy-first, optional) ---
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
ULTRA_OLLAMA_MODEL=llama3.1

# --- Model overrides (optional; defaults preserve shipped models) ---
ULTRA_OPENAI_MODEL=gpt-5.1
ULTRA_ANTHROPIC_MODEL=claude-sonnet-4-5
ULTRA_GEMINI_MODEL=gemini-2.5-pro

# --- Behaviour ---
ULTRA_MAX_TOKENS=1800
ULTRA_MAX_ASPECTS=4
# If set, every run writes a JSON audit trail into this directory:
ULTRA_AUDIT_DIR=
